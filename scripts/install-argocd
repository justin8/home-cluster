#!/usr/bin/env bash

set -euo pipefail

ARGOCD_NAMESPACE="argocd"
ARGOCD_HELM_RELEASE="argo-cd"
ARGOCD_CHART_VERSION="7.7.16"

# 🔐 Check for SOPS key early
if [[ ! -f ".sops-age.key" ]]; then
    echo "❌ ERROR: .sops-age.key not found. This is required for secret management."
    echo "   Ensure you are running in a nix-shell or have the key in the project root."
    exit 1
fi

echo "🚀 Installing Argo CD ${ARGOCD_CHART_VERSION} via Helm..."

# Create the namespace if it doesn't exist
kubectl create namespace "${ARGOCD_NAMESPACE}" --dry-run=client -o yaml | kubectl apply -f -

# Install ArgoCD via Helm using the same release name the self-managed app expects.
# This prevents a duplicate install when ArgoCD takes over its own management.
helm upgrade --install "${ARGOCD_HELM_RELEASE}" argo-cd \
    --repo https://argoproj.github.io/argo-helm \
    --version "${ARGOCD_CHART_VERSION}" \
    --namespace "${ARGOCD_NAMESPACE}" \
    --values kubernetes/values/global.yaml \
    --wait

echo "✅ Argo CD is installed!"

echo "🔐 Bootstrapping SOPS Age key..."
kubectl create secret generic sops-age \
    --namespace "${ARGOCD_NAMESPACE}" \
    --from-file=age.agekey=.sops-age.key \
    --dry-run=client -o yaml | kubectl apply -f -
echo "✅ SOPS Age key bootstrapped!"

echo "🌱 Applying Root Application (App of Apps)..."
kubectl apply -f kubernetes/bootstrap/root.yaml

echo "🎉 Setup complete! You can access the Argo CD UI via port-forward:"
echo "   kubectl port-forward svc/argo-cd-argocd-server -n argocd 8080:443"
