#!/usr/bin/env bash
set -euo pipefail

# Configuration
VM_NAME="talos-vm"
MAC_ADDR="52:54:00:12:34:56"
RAM_MB=14336
VCPUS=8
DISK_SIZE_GB=100
BRIDGE_IF="br0"
LIBVIRT_IMAGE_DIR="/var/lib/libvirt/images"

# Environment
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
TALOS_DIR="$REPO_ROOT/talos"

echo "Determining Talos ISO URL..."
ISO_URL=$(
  cd "$TALOS_DIR"
  talhelper genurl image
)
# Extract Hash and Version from URL
# URL format: https://factory.talos.dev/image/HASH/VERSION/metal-amd64.iso
HASH=$(echo "$ISO_URL" | cut -d/ -f5)
VERSION=$(echo "$ISO_URL" | cut -d/ -f6)
ISO_NAME="${VERSION}-${HASH}.iso"

LOCAL_ISO_PATH="$REPO_ROOT/$ISO_NAME"
DEST_ISO_PATH="$LIBVIRT_IMAGE_DIR/$ISO_NAME"

if [[ ! -f "$DEST_ISO_PATH" ]]; then
  echo "Downloading ISO: $ISO_NAME"
  curl -L -o "$LOCAL_ISO_PATH" "$ISO_URL"
  echo "Copying ISO to libvirt directory (requires sudo)..."
  sudo mv "$LOCAL_ISO_PATH" "$DEST_ISO_PATH"
  sudo chown qemu:qemu "$DEST_ISO_PATH" 2>/dev/null || true
else
  echo "ISO $ISO_NAME already exists."
fi

echo "Creating VM: $VM_NAME (MAC: $MAC_ADDR)"
sudo virsh undefine "$VM_NAME" || :
sudo virt-install \
  --name "$VM_NAME" \
  --ram "$RAM_MB" \
  --vcpus "$VCPUS" \
  --os-variant fedora-unknown \
  --disk size="$DISK_SIZE_GB",bus=virtio \
  --cdrom "$DEST_ISO_PATH" \
  --network bridge="$BRIDGE_IF",model=virtio,mac="$MAC_ADDR" \
  --graphics vnc \
  --noautoconsole \
  --boot cdrom,hd

echo "VM $VM_NAME created and starting."

echo "Waiting for VM to acquire an IP (listening on $BRIDGE_IF for MAC $MAC_ADDR)..."
# tcpdump -c 1: Exit after catching one packet
# ether src: Only packets coming FROM the VM
# and not ip src 0.0.0.0: Ignore the initial DHCP discovery phase
# grep -oP: Extract only the IP address part (stopping before the port)
VM_IP=$(sudo tcpdump -i "$BRIDGE_IF" -n -c 1 "ether src $MAC_ADDR and ip and not ip src 0.0.0.0" 2>/dev/null | grep -oP '(?<=IP )\d+\.\d+\.\d+\.\d+' | head -n 1)

if [[ -n "$VM_IP" ]]; then
  echo "--------------------------------------------------"
  echo "VM IP Found: $VM_IP"
  echo "--------------------------------------------------"
else
  echo "Failed to detect IP address automatically."
fi
