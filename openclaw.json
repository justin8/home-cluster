{
  "gateway": {
    "mode": "local",
    "bind": "0.0.0.0",
    "port": 18789,
    "auth": {
      "mode": "trusted-proxy",
      "trustedProxy": {
        "userHeader": "Remote-User",
        "allowUsers": ["justin"]
      }
    },
    "trustedProxies": ["10.244.0.0/16", "100.64.0.0/10"],
    "controlUi": {
      "enabled": true,
      "allowedOrigins": ["https://claw.dray.id.au"]
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "models": {
        "openrouter/auto": {
          "alias": "OpenRouter"
        },
        "openrouter/amazon/nova-pro-v1": {},
        "openrouter/anthropic/claude-sonnet-4.6": {},
        "openrouter/anthropic/claude-opus-4.6": {},
        "openrouter/google/gemini-3-flash-preview": {}
      },
      "model": {
        "primary": "openrouter/auto",
        "fallbacks": [
          "openrouter/amazon/nova-pro-v1",
          "openrouter/anthropic/claude-sonnet-4.6",
          "openrouter/anthropic/claude-opus-4.6",
          "openrouter/google/gemini-3-flash-preview"
        ]
      }
    },
    "list": [
      {
        "id": "default",
        "name": "OpenClaw Assistant",
        "workspace": "/home/node/.openclaw/workspace"
      }
    ]
  },
  "cron": {
    "enabled": false
  },
  "plugins": {
    "entries": {
      "openrouter": {
        "enabled": true
      }
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.4.12",
    "lastTouchedAt": "2026-04-14T06:19:17.536Z"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "",
      "dmPolicy": "pairing"
    }
  }
}
